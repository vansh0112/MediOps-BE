# =============================================================================
# MediOps-BE Environment Variables
# =============================================================================
# Copy to .env.development, .env.staging, or .env.production and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Database (Supabase = PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# -----------------------------------------------------------------------------
# Required: Document storage (PDFs, images)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# LLM: AWS Bedrock (used for discharge/bill/report parsing + justification)
# -----------------------------------------------------------------------------
# Uses IAM credentials or these env vars. No separate "Bedrock API key".
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=8000
