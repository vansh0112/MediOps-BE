# =============================================================================
# MediOps-BE Environment Variables
# =============================================================================
# Copy to .env.development, .env.staging, or .env.production and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Database (Supabase = PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Backend must use service_role key (bypasses RLS). Never use this on the frontend.
SUPABASE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Required: Document storage (PDFs, images)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# LLM: AWS Bedrock (used for discharge/bill/report parsing + justification)
# -----------------------------------------------------------------------------
# Uses IAM credentials or these env vars. No separate "Bedrock API key".
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# Optional: override Bedrock model (inference profile ID). Default: us.anthropic.claude-3-5-sonnet-20241022-v2:0
# For other regions use e.g. apac.anthropic.claude-3-5-sonnet-20241022-v2:0 or eu.*
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=8000
