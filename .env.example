# =============================================================================
# MediOps-BE Environment Variables
# =============================================================================
# Copy to .env.development, .env.staging, or .env.production and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Database (Supabase = PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Backend must use service_role key (bypasses RLS). Never use this on the frontend.
SUPABASE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Required: Document storage (PDFs, images)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# LLM: OpenAI (used for discharge/bill/report parsing + justification)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
# Central model switch (one place). Example: gpt-5.2
OPENAI_MODEL=gpt-5.2

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=8000
